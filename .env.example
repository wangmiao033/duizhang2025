# -----------------------------------------------------------------------------
#  duizhang2025 — 环境变量模板
#  复制为 .env 后按需填写；不要提交包含真实密钥的 .env
# -----------------------------------------------------------------------------

# 前端请求后端 API 的基地址（Vite：须以 VITE_ 开头）
VITE_API_BASE_URL=https://caiwuapi.hnchpower.cn

# Neon PostgreSQL（后续 FastAPI 从 DATABASE_URL 读取）
# 应用默认优先使用 pooled 连接串（高并发、经 Neon 连接池）
# direct 可用于迁移工具（如 Alembic）或需要直连的特殊场景
DATABASE_URL=
DATABASE_URL_POOLED=
DATABASE_URL_DIRECT=
